// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "auto_update": false,
  "autosave": "on_window_change",
  "buffer_font_size": 16,
  "buffer_font_family": "JetBrains Mono",
  "cursor_blink": false,
  "format_on_save": "off",
  "git": {
    "inline_blame": {
      "enabled": false
    }
  },
  "languages": {
    "Python": {
      "language_servers": [
        "ty",
        "!pyright",
        "!ruff"
      ],
      "formatter": [
        {
          "code_action": "source.organizeImports.ruff"
        },
        {
          "code_action": "source.fixAll.ruff"
        },
        {
          "language_server": {
            "name": "ruff"
          }
        }
      ],
      "format_on_save": "off"
    },
    "Rust": {
      "formatter": "language_server",
      "format_on_save": "on"
    },
    "JSONC": {
      "formatter": "language_server",
      "format_on_save": "on"
    }
  },
  "lsp": {
    "ty": {
      "settings": {
        // "configurationFile": "ty.toml",
        // "configuration": {
        //   "environment": {
        //     "python": ".venv/bin/python"
        //   }
        // }
      },
      "initialization_options": {
        "logLevel": "debug",
        "logFile": "~/.cache/zed/ty.log"
      },
      "binary": {
        "path": "/Users/dhruv/work/astral/ruff/target/debug/ty",
        "arguments": [
          "server"
        ]
      }
    },
    "ruff": {
      "initialization_options": {
        "settings": {
          "logLevel": "debug",
          "logFile": "~/.cache/zed/ruff.log"
        }
      }
      // "binary": {
      //   "path": "/Users/dhruv/work/astral/ruff/target/debug/ruff",
      //   "arguments": [
      //     "server"
      //   ]
      // },
    },
    "rust-analyzer": {
      // These should match the ones in `./../nvim/lua/dm/lsp/servers.lua`
      "initialization_options": {
        "cargo": {
          "features": "all",
          "buildScripts": {
            "enable": true
          }
        },
        // "checkOnSave": false,
        "check": {
          "command": "clippy"
        },
        "inlayHints": {
          "closingBraceHints": {
            "enable": false
          }
        },
        "procMacro": {
          "enable": true
        },
        "references": {
          "excludeImports": true
        }
      }
    }
  },
  "preview_tabs": {
    "enable_preview_from_file_finder": true
  },
  "scrollbar": {
    "show": "never"
  },
  "show_edit_predictions": false,
  "soft_wrap": "editor_width",
  "tabs": {
    "file_icons": true
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "theme": {
    "mode": "system",
    "dark": "Gruvbox Dark",
    "light": "Gruvbox Light"
  },
  "vim_mode": true
}
